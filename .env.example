# MWDB (https://mwdb.cert.pl) - API key from your account settings
MWDB_API_KEY=your_mwdb_api_key_here
MWDB_URL=https://mwdb.cert.pl/api/

# Gmail - use an App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_RECIPIENT=recipient@example.com

# VirusTotal - free API key from https://www.virustotal.com (500 req/day)
VT_API_KEY=your_virustotal_api_key_here

# MobSF - optional dynamic analysis (requires Docker)
# Start: docker run -it --rm -p 8000:8000 opensecurity/mobile-security-framework-mobsf
# API key: visible in MobSF web UI top-right corner after starting
MOBSF_URL=http://localhost:8000
MOBSF_API_KEY=your_mobsf_api_key_here
# Set to true only if Android emulator is connected to MobSF
MOBSF_DYNAMIC=false
